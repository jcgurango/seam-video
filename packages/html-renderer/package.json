{
  "name": "@seam/html-renderer",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node-fonts": {
      "import": "./dist/node-fonts.js",
      "types": "./dist/node-fonts.d.ts"
    },
    "./browser-fonts": {
      "import": "./dist/browser-fonts.js",
      "types": "./dist/browser-fonts.d.ts"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@jcgurango/satori": "^0.27.0",
    "satori-html": "^0.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.5.0"
  }
}
