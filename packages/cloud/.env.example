# Seam Cloud configuration

# Bootstrap admin account (REQUIRED — startup fails without these).
ADMIN_USER=admin@example.com
ADMIN_PASS=change-me-please

# HTTP port (default 8787).
PORT=8787

# Directory for the SQLite DB + on-disk media/projects (default ./data).
DATA_DIR=./data

# Secret for signing sessions/cookies (set a long random value in production).
BETTER_AUTH_SECRET=

# Public base URL (default http://localhost:$PORT). Set when behind a proxy.
BETTER_AUTH_URL=

# Allowed origins for the web editor. Governs BOTH the CORS layer AND
# better-auth's Origin allowlist (an untrusted origin gets "403 Invalid
# Origin" on sign-in). "*" (default) trusts any origin — safe here because the
# editor authenticates with a bearer token, not cookies. Comma-separate to lock
# down, e.g. CORS_ORIGIN=https://editor.example.com,http://localhost:5173
CORS_ORIGIN=
